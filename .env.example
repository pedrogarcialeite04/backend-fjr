# ══════════════════════════════════════════════════════════════════════════
# FJS Topografia — Variáveis de Ambiente (EXEMPLO)
# ══════════════════════════════════════════════════════════════════════════
# Copie este arquivo como .env e preencha os valores.
# Na Vercel, configure em: Settings > Environment Variables
# ══════════════════════════════════════════════════════════════════════════

# ── Servidor
PORT=3000
NODE_ENV=development

# ── URLs / CORS (separar múltiplos domínios por vírgula)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── MongoDB
# Local: mongodb://localhost:27017/fjs_topografia
# Atlas: mongodb+srv://usuario:senha@cluster.xxxxx.mongodb.net/fjs_topografia
# Vercel/Atlas: em Network Access, permita 0.0.0.0/0 (ou regra equivalente) senão o deploy retorna 503.
MONGODB_URI=mongodb://localhost:27017/fjs_topografia

# ── JWT (use chaves fortes >= 32 chars em produção)
JWT_SECRET=coloque_uma_chave_forte_com_32_chars_ou_mais_aqui
JWT_REFRESH_SECRET=coloque_outra_chave_forte_diferente_aqui
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookies
COOKIE_SECURE=false
COOKIE_SAMESITE=strict

# ── Upload
MAX_FILE_SIZE=5242880
ALLOWED_TYPES=image/jpeg,image/png,image/webp

# ── Observabilidade
LOG_LEVEL=info

# ── Admin Seed (usado pelo comando: npm run seed)
SEED_ADMIN_EMAIL=admin@fjs-topografia.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=sua_senha_forte_aqui
SEED_ADMIN_NAME=Admin
